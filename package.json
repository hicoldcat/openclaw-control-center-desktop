{
  "name": "openclaw-control-center-desktop",
  "version": "0.1.0",
  "description": "Electron desktop wrapper for openclaw-control-center",
  "main": "electron/main.cjs",
  "scripts": {
    "sync:upstream": "node scripts/sync-upstream.cjs",
    "start": "electron .",
    "dist": "electron-builder --publish never"
  },
  "build": {
    "appId": "com.hicoldcat.openclaw.controlcenter.desktop",
    "productName": "OpenClaw Control Center Desktop",
    "icon": "assets/icon.png",
    "asar": false,
    "files": [
      "electron/**/*",
      "assets/**/*",
      "upstream/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/windows/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "assets/macos/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "icon": "assets/linux/icons",
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "electron": "^37.2.3",
    "electron-builder": "^26.0.12"
  }
}
